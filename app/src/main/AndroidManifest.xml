<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android">

    <uses-permission android:name="android.permission.FOREGROUND_SERVICE" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE_MEDIA_PLAYBACK" />
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS" />
    <!-- direct-path reads of the shared Music folder for the refresh
         action (audio-only is all cmus needs; no SAF) -->
    <uses-permission android:name="android.permission.READ_MEDIA_AUDIO" />

    <!-- backup was previously default-on and unscoped (all of filesDir);
         the rules scope it to prefs + the core cmus state. minSdk 34 > 31,
         so only dataExtractionRules is ever read (no fullBackupContent) -->
    <application
        android:label="@string/app_name"
        android:icon="@mipmap/ic_launcher"
        android:theme="@style/Theme.Cmus"
        android:dataExtractionRules="@xml/backup_rules">

        <activity
            android:name=".MainActivity"
            android:exported="true">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <!-- stage 18: stock Material day/night, deliberately not cmus-themed -->
        <activity
            android:name=".SettingsActivity"
            android:label="Settings"
            android:exported="false"
            android:theme="@style/Theme.Cmus.Settings"
            android:parentActivityName=".MainActivity" />

        <service
            android:name=".CmusService"
            android:exported="false"
            android:foregroundServiceType="mediaPlayback" />

        <!-- media-key resurrection target after the session is gone
             (MediaSession#setMediaButtonBroadcastReceiver); the system
             routes keys to the live session while one exists -->
        <receiver
            android:name=".MediaButtonReceiver"
            android:exported="true">
            <intent-filter>
                <action android:name="android.intent.action.MEDIA_BUTTON" />
            </intent-filter>
        </receiver>

        <!-- debug-only (gated on FLAG_DEBUGGABLE); driven from root adb -->
        <receiver
            android:name=".CmusDebugReceiver"
            android:exported="false" />

    </application>

</manifest>
