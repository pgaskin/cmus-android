<?xml version="1.0" encoding="utf-8"?>
<resources>
    <!-- night variant of the settings theme; see values/styles.xml -->
    <style name="Theme.Cmus.Settings" parent="android:Theme.Material">
        <item name="android:colorAccent">@color/settings_accent</item>
        <item name="android:colorPrimary">@color/settings_accent</item>
        <item name="android:colorEdgeEffect">@color/settings_accent</item>
        <!-- keep the accent for switches/headers, but darken the action bar
             itself (colorPrimary would otherwise paint it the light accent) -->
        <item name="android:actionBarStyle">@style/Widget.Cmus.Settings.ActionBar</item>
    </style>

    <style name="Widget.Cmus.Settings.ActionBar" parent="android:Widget.Material.ActionBar.Solid">
        <item name="android:background">@color/settings_action_bar</item>
    </style>
</resources>
