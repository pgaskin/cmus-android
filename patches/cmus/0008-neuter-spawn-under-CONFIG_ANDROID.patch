From 70f5bea1899754cf71a1ae1f046101f272e5858e Mon Sep 17 00:00:00 2001
From: "Claude Opus 4.8" <noreply@anthropic.com>
Date: Sun, 19 Jul 2026 19:51:10 -0400
Subject: [PATCH 8/8] neuter spawn() under CONFIG_ANDROID

The app does not permit cmus to run external processes (status display
programs, the run/shell commands): under CONFIG_ANDROID spawn() fails with
EPERM instead of fork()+execvp(). All three callers already handle -1.

diff --git a/spawn.c b/spawn.c
index 117d120..e76a072 100644
--- a/spawn.c
+++ b/spawn.c
@@ -26,6 +26,16 @@
 #include <fcntl.h>
 #include <errno.h>
 
+#ifdef CONFIG_ANDROID
+/* the app does not permit cmus to run external processes (status display
+ * programs, the `run`/`shell` commands): fail like a denied exec. Callers all
+ * handle the -1. */
+int spawn(char *argv[], int *status, int do_wait)
+{
+	errno = EPERM;
+	return -1;
+}
+#else
 int spawn(char *argv[], int *status, int do_wait)
 {
 	pid_t pid;
@@ -108,3 +118,4 @@ int spawn(char *argv[], int *status, int do_wait)
 		return 0;
 	}
 }
+#endif
