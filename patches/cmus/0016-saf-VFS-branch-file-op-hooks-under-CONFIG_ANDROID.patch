 #include <sys/types.h>
 #include <sys/stat.h>
@@ -132,11 +133,19 @@ static int add_pl_line(void *data, const char *line)
 static int do_browser_load(const char *name)
 {
 	struct stat st;
+	int saf = 0;
 
-	if (stat(name, &st))
+#ifdef CONFIG_ANDROID
+	/* a raw stat() ENOENTs on a /saf pseudo-path, and the browser only ever
+	 * loads directories (it plays/adds files rather than loading them), so
+	 * treat any /saf path as a directory and skip the stat/playlist probe */
+	saf = is_saf_path(name);
+#endif
+
+	if (!saf && stat(name, &st))
 		return -1;
 
-	if (S_ISREG(st.st_mode) && cmus_is_playlist(name)) {
+	if (!saf && S_ISREG(st.st_mode) && cmus_is_playlist(name)) {
 		char *buf;
 		ssize_t size;
 
@@ -155,7 +164,7 @@ static int do_browser_load(const char *name)
 			cmus_playlist_for_each(buf, size, 0, add_pl_line, NULL);
 			munmap(buf, size);
 		}
-	} else if (S_ISDIR(st.st_mode)) {
+	} else if (saf || S_ISDIR(st.st_mode)) {
 		int (*filter)(const char *, const struct stat *) = normal_filter;
 		struct directory dir;
 		const char *str;
diff --git a/cache.c b/cache.c
index 38034b1..78dbb3a 100644
--- a/cache.c
+++ b/cache.c
@@ -443,7 +443,20 @@ static struct track_info *ip_get_ti(const char *filename)
 		ti->bitrate = ip_bitrate(ip);
 		ti->codec = ip_codec(ip);
 		ti->codec_profile = ip_codec_profile(ip);
-		ti->mtime = ip_is_remote(ip) ? -1 : file_get_mtime(filename);
+		if (ip_is_remote(ip))
+			ti->mtime = -1;
+#ifdef CONFIG_ANDROID
+		else if (is_saf_path(filename)) {
+			/* a STAT RPC, not a raw stat() (which ENOENTs on /saf) —
+			 * and the same mtime source cache_refresh compares against,
+			 * so a later Refresh metadata sees a stable value */
+			struct saf_stat ss;
+			ti->mtime = saf_stat(filename, &ss) == 0
+				? (time_t)ss.mtime : -1;
+		}
+#endif
+		else
+			ti->mtime = file_get_mtime(filename);
 	}
 	ip_delete(ip);
 	return ti;
@@ -520,6 +533,28 @@ struct track_info **cache_refresh(int *count, int force)
 		 */
 
 		if (!is_url(ti->filename)) {
+#ifdef CONFIG_ANDROID
+			if (is_saf_path(ti->filename)) {
+				/* per-file STAT RPC: no enumerating LIST to
+				 * piggyback on here (contrast recursive add) */
+				struct saf_stat ss;
+				int sr = saf_stat(ti->filename, &ss);
+				if (sr < 0) {
+					if (saf_errno(sr) == ENOENT) {
+						rc = -1;	/* vanished: drop */
+					} else {
+						/* transient bridge error (I/O or
+						 * a cancel) — leave the track be */
+						track_info_unref(ti);
+						tis[i] = NULL;
+						continue;
+					}
+				} else {
+					rc = 0;
+					st.st_mtime = (time_t)ss.mtime;
+				}
+			} else
+#endif
 			rc = stat(ti->filename, &st);
 			if (!rc && !force && ti->mtime == st.st_mtime) {
 				// unchanged
diff --git a/input.c b/input.c
index 54bc802..54046f5 100644
--- a/input.c
+++ b/input.c
@@ -35,6 +35,7 @@
 #include "locking.h"
 #include "xstrjoin.h"
 #include "static_plugins.h"
+#include "android.h"
 
 #include <unistd.h>
 #include <stdbool.h>
@@ -433,6 +434,9 @@ static void ip_init(struct input_plugin *ip, char *filename)
 		.bitrate            = -1,
 		.data = {
 			.fd         = -1,
+#ifdef CONFIG_ANDROID
+			.saf_extra_fd = -1,
+#endif
 			.filename   = filename,
 			.remote     = is_http_url(filename),
 			.channel_map = CHANNEL_MAP_INIT
@@ -444,8 +448,17 @@ static void ip_init(struct input_plugin *ip, char *filename)
 static void ip_reset(struct input_plugin *ip, int close_fd)
 {
 	int fd = ip->data.fd;
+#ifdef CONFIG_ANDROID
+	int extra_fd = ip->data.saf_extra_fd;
+#endif
 	free(ip->data.metadata);
 	ip_init(ip, ip->data.filename);
+#ifdef CONFIG_ANDROID
+	/* a sidecar bridge fd (wavpack .wvc) always dies with the input; ip_init
+	 * has reset the field to -1 */
+	if (extra_fd != -1)
+		close(extra_fd);
+#endif
 	if (fd != -1) {
 		if (close_fd)
 			close(fd);
@@ -460,6 +473,34 @@ char *ip_reopen_path(struct input_plugin_data *ip_data, const char *sidecar)
 {
 	if (is_url(ip_data->filename))
 		return NULL;
+#ifdef CONFIG_ANDROID
+	if (is_saf_path(ip_data->filename)) {
+		char *path = xnew(char, sizeof("/proc/self/fd/") + 20);
+		int fd;
+
+		if (!sidecar) {
+			/* an independent, seekable re-open of the already-open
+			 * bridge fd via its /proc/self/fd magic symlink — gives
+			 * the tag readers their own file offset without a dup() */
+			sprintf(path, "/proc/self/fd/%d", ip_data->fd);
+			return path;
+		}
+		/* a same-directory companion (wavpack's .wvc): issue a fresh
+		 * bridge OPEN for its /saf path and hand back /proc/self/fd. The
+		 * new bridge fd's lifetime rides the input — closed in ip_reset,
+		 * after the plugin has re-opened the symlink for its own handle */
+		fd = saf_open(sidecar);
+		if (fd < 0) {
+			free(path);
+			return NULL;
+		}
+		if (ip_data->saf_extra_fd != -1)
+			close(ip_data->saf_extra_fd);
+		ip_data->saf_extra_fd = fd;
+		sprintf(path, "/proc/self/fd/%d", fd);
+		return path;
+	}
+#endif
 	return xstrdup(sidecar ? sidecar : ip_data->filename);
 }
 
@@ -478,9 +519,21 @@ static int open_file_locked(struct input_plugin *ip)
 	if (!ops)
 		return -IP_ERROR_UNRECOGNIZED_FILE_TYPE;
 
-	ip->data.fd = open(ip->data.filename, O_RDONLY);
-	if (ip->data.fd == -1)
-		return -IP_ERROR_ERRNO;
+#ifdef CONFIG_ANDROID
+	if (is_saf_path(ip->data.filename)) {
+		int fd = saf_open(ip->data.filename);
+		if (fd < 0) {
+			errno = saf_errno(fd);
+			return -IP_ERROR_ERRNO;
+		}
+		ip->data.fd = fd;
+	} else
+#endif
+	{
+		ip->data.fd = open(ip->data.filename, O_RDONLY);
+		if (ip->data.fd == -1)
+			return -IP_ERROR_ERRNO;
+	}
 
 	while (1) {
 		ip->ops = ops;
