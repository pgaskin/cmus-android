diff --git a/load_dir.c b/load_dir.c
index 007ecfb..3062391 100644
--- a/load_dir.c
+++ b/load_dir.c
@@ -18,6 +18,7 @@
 
 #include "load_dir.h"
 #include "xmalloc.h"
+#include "android.h"
 
 #include <sys/types.h>
 #include <sys/stat.h>
@@ -34,6 +35,28 @@ int dir_open(struct directory *dir, const char *name)
 		return -1;
 	}
 
+#ifdef CONFIG_ANDROID
+	dir->saf_entries = NULL;
+	dir->saf_count = 0;
+	dir->saf_pos = 0;
+	if (is_saf_path(name)) {
+		/* one LIST RPC fetches the whole child listing; dir_read then
+		 * walks it with no further round-trips. dir->d stays NULL to
+		 * mark this mode. */
+		int rc = saf_list(name, &dir->saf_entries, &dir->saf_count);
+		if (rc < 0) {
+			errno = saf_errno(rc);
+			return -1;
+		}
+		dir->d = NULL;
+		memcpy(dir->path, name, len);
+		dir->path[len++] = '/';
+		dir->path[len] = 0;
+		dir->len = len;
+		return 0;
+	}
+#endif
+
 	dir->d = opendir(name);
 	if (!dir->d)
 		return -1;
@@ -47,16 +70,49 @@ int dir_open(struct directory *dir, const char *name)
 
 void dir_close(struct directory *dir)
 {
+#ifdef CONFIG_ANDROID
+	if (!dir->d) {
+		saf_list_free(dir->saf_entries, dir->saf_count);
+		dir->saf_entries = NULL;
+		return;
+	}
+#endif
 	closedir(dir->d);
 }
 
 const char *dir_read(struct directory *dir)
 {
-	DIR *d = dir->d;
+	DIR *d;
 	int len = dir->len;
 	char *full = dir->path;
 	struct dirent *de;
 
+#ifdef CONFIG_ANDROID
+	if (!dir->d) {
+		/* /saf mode: iterate the cached LIST result. SAF has no symlinks;
+		 * synthesize just the stat fields load_dir's callers read
+		 * (S_ISDIR + size/mtime). The app supplies the ".." entry. */
+		while (dir->saf_pos < dir->saf_count) {
+			struct saf_dirent *e = &dir->saf_entries[dir->saf_pos++];
+			int nlen = strlen(e->name);
+
+			if (len + nlen + 1 >= (int)sizeof(dir->path))
+				continue;
+			memcpy(full + len, e->name, nlen + 1);
+			memset(&dir->st, 0, sizeof(dir->st));
+			dir->st.st_mode = e->is_dir ? (S_IFDIR | 0755)
+						    : (S_IFREG | 0644);
+			dir->st.st_size = e->size;
+			dir->st.st_mtime = e->mtime;
+			dir->is_link = 0;
+			return full + len;
+		}
+		return NULL;
+	}
+#endif
+
+	d = dir->d;
+
 #if defined(__CYGWIN__)
 	/* Fix for cygwin "hang" bug when browsing /
 	 * Windows treats // as a network path.
diff --git a/load_dir.h b/load_dir.h
index 06168cc..132c733 100644
--- a/load_dir.h
+++ b/load_dir.h
@@ -23,6 +23,8 @@
 #include <stdlib.h>
 #include <dirent.h>
 
+struct saf_dirent;
+
 struct directory {
 	DIR *d;
 	int len;
@@ -31,6 +33,13 @@ struct directory {
 	/* stat() information. ie. for the symlink target */
 	struct stat st;
 	char path[1024];
+#ifdef CONFIG_ANDROID
+	/* a /saf listing fetched in one LIST RPC; dir_read walks it in place of
+	 * readdir(). dir->d is NULL in this mode. */
+	struct saf_dirent *saf_entries;
+	size_t saf_count;
+	size_t saf_pos;
+#endif
 };
 
 int dir_open(struct directory *dir, const char *name);
