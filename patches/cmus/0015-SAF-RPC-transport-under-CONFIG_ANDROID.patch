+/*
+ * SAF RPC transport (patch 0015).
+ *
+ * A second, dedicated AF_UNIX channel to the app that services the /saf
+ * pseudo-paths (patch 0016): directory LIST, file OPEN (the fd is passed
+ * back over SCM_RIGHTS), and STAT. It is deliberately separate from the
+ * event/command socket above so that a blocking request issued from the
+ * worker or player-consumer thread never interleaves with the main loop's
+ * command stream, and it is correlation-id multiplexed so the three issuer
+ * threads (main/worker/consumer) don't head-of-line-block each other.
+ *
+ * Enabled only when $CMUS_ANDROID_SAF_SOCKET is set (the app binds a
+ * private-dir path and connects); otherwise every call below fails
+ * cleanly. The /saf VFS hooks that call these land in patch 0016 — this
+ * patch is transport only and changes no file-op behavior on its own.
+ *
+ * All calls block until the app answers (it services SAF on its own
+ * thread and never calls back into cmus, so there is no deadlock) and are
+ * safe to call concurrently from any thread. They return 0 on success and
+ * a negative SAF_E* code on failure (see android.c); -SAF_ENOTSEEK marks
+ * an OPEN that returned a non-seekable fd.
+ */
+struct saf_dirent {
+	char *name;
+	int is_dir;
+	int64_t size;
+	int64_t mtime;
+};
+
+struct saf_stat {
+	int64_t size;
+	int64_t mtime;
+};
+
+int saf_enabled(void);
+/* returns a seekable fd (>= 0) or a negative SAF_E* code */
+int saf_open(const char *path);
+int saf_stat(const char *path, struct saf_stat *st);
+/* on success stores a malloc'd array (free with saf_list_free) + its count */
+int saf_list(const char *path, struct saf_dirent **entries, size_t *count);
+void saf_list_free(struct saf_dirent *entries, size_t count);
+
 #else
 
