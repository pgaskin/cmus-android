+/*
+ * App-facing IPC socket for the Android wrapper app.
+ *
+ * A unix stream socket is bound at $CMUS_ANDROID_SOCKET (unset = disabled;
+ * the same binary runs unchanged outside the app). One client at a time; a
+ * new connection replaces the old one and always starts with a full
+ * snapshot, so reconnecting is the fix for everything.
+ *
+ * Outbound: newline-delimited JSON, one object per line, each with a
+ * "type" field. Strings are made valid UTF-8 (invalid bytes become <xx>,
+ * see u_to_utf8) and JSON-escaped. Events are composed and flushed at most
+ * once per main-loop iteration:
+ *
+ *   {"type":"hello","version":"..."}
+ *       first line after connect
+ *   {"type":"status","status":"stopped|playing|paused","file":...,
+ *    "duration":n,"position":n.nnn,"tags":{"key":"val",...}}
+ *       on connect and whenever the playback status, track, or metadata
+ *       changes; without a current track only "status" is present.
+ *       Tag keys are as stored in the file, lowercased by cmus, and may
+ *       repeat (e.g. multiple artists).
+ *   {"type":"position","position":n.nnn}
+ *       position advance/seek, sent when the whole second changes
+ *       (<= 1/s while playing) but carrying the exact fractional
+ *       position so clients animating between events don't jump on
+ *       rebase; only sent when no status event is sent this flush
+ *       (status carries position too)
+ *   {"type":"volume","left":n,"right":n}
+ *       percent, -1 = unknown; on connect and on change
+ *   {"type":"view","view":"tree|sorted|playlist|queue|browser|filters|settings"}
+ *       the active view (the 1-7 keys / `view` command); on connect and
+ *       on change
+ *   {"type":"filter","filter":"..."}
+ *       the library live filter (the `live-filter` command: plain text =
+ *       substring match over all tags, `~`-style expressions per
+ *       expr_is_short; narrows the tree/sorted views only); on connect
+ *       and on change, the field omitted when unset. Changes don't only
+ *       come from commands — the resume file restores it at startup and
+ *       lib_set_filter (filters-view activation) silently clears it, so
+ *       this is diffed against the actual lib state every flush.
+ *   {"type":"options","options":{"name":"value",...}}
+ *       every cmus option as the string its getter returns (includes all
+ *       color_*); on connect and after any executed command, coalesced
+ *       per main-loop iteration (a colorscheme's ~40 sets = one event)
+ *   {"type":"selected","view":"...","files":["/path",...],
+ *    "playlists":["name",...]}
+ *       sent when a right-click resolves to a track-list row (the
+ *       selection has already moved to it): the exact file set win-remove
+ *       would act on, marked-tracks rule included, plus the current
+ *       playlist names for an add-to-playlist chooser. Only emitted where
+ *       win-remove acts without a confirmation prompt — tree/sorted/queue
+ *       plus the playlist view's track pane; browser/filters/settings
+ *       removes go through yes_no_query, which blocks the main loop
+ *       reading the pty. That's what makes this usable as the app's
+ *       item-action trigger.
+ *   {"type":"selected","view":"playlist","playlist":"name"}
+ *       the playlist-view list pane variant: a right-click there selects
+ *       (and shows) that playlist, and this carries its name so the app
+ *       can offer android-pl-delete — win-remove would prompt.
+ *   {"type":"jobs","running":true|false}
+ *       whether any worker job (add/update scans — imports the app must
+ *       not idle-quit mid-flight, and whose completion it toasts) is
+ *       running; on connect and on change, plus immediately as the
+ *       answer to the android-jobs line below. The diff is reliable
+ *       promptness-wise because job activity itself wakes the main loop
+ *       (job_fd is in the select set), so transitions always reach the
+ *       next flush.
+ *   {"type":"saved","what":["kind",...]}
+ *       an android-save line below finished writing the named kinds; the
+ *       app's cue to read the state files (zip export) and to clear its
+ *       debounce state (periodic saves). Acks arrive in request order
+ *       (one socket, commands processed serially), so FIFO matching is
+ *       exact; "what" makes it checkable.
+ *   {"type":"dirty","what":["kind",...]}
+ *       unsaved state-file changes, the app's periodic-save trigger.
+ *       Kinds: library (lib.pl), cache, playlist (playlists/), queue
+ *       (queue.pl), history (command+search). Edge-triggered per save
+ *       cycle: per-kind mutation counters are diffed in the flush
+ *       against the value at the last android-save of that kind, and a
+ *       kind is re-announced only after it's saved and mutated again —
+ *       so a debouncing client sees at most one event per kind per
+ *       cycle, and a mutation landing *during* a save (worker-thread
+ *       cache writes) re-announces on the next flush because the saved
+ *       marker was snapshotted before the files were written. On
+ *       connect, kinds dirty since their last save are (re-)announced
+ *       in the snapshot, so a reconnect loses no dirt. resume/settings
+ *       never announce (cmus-side writers don't exist for resume, and
+ *       options changes already echo as the options event); they're
+ *       save selectors only. Note the startup restore itself dirties
+ *       library/queue/playlist (the autoload jobs are ordinary adds),
+ *       so one small-file save cycle per spawn is expected — but known
+ *       cache entries don't re-bump, keeping the big rewrite out of it.
+ *   {"type":"colorscheme","name":"..."}
+ *       a `colorscheme` command successfully sourced the named theme
+ *       file (either search dir; a failed lookup emits nothing).
+ *       Transient like "selected": a theme is just a batch of set
+ *       commands and cmus doesn't retain the name, so there's nothing
+ *       to snapshot on connect — the resulting color_* values arrive
+ *       in the coalesced options event as usual.
+ *
+ * Inbound: raw cmus command lines, newline-delimited — exactly what the
+ * server.c socket accepts ("player-pause", "seek +5", ...), including the
+ * "/" and "?" search prefixes. No acks; errors show in the TUI. State
+ * changes come back as events.
+ *
+ * App-intent lines are resolved here instead of being cmus commands
+ * (they need state only cmus has, or take a verbatim name where command
+ * tokenization would need quoting):
+ *   android-nav-left / android-nav-right
+ *       directional navigation for the app's joystick: the inner pane in
+ *       the two-pane views (win-next), or the adjacent view once at that
+ *       side's edge / in a single-pane view (left-view/right-view -n — a
+ *       spatial gesture shouldn't wrap around).
+ *   android-selected
+ *       emit a selected event for the *current* selection, the same one a
+ *       list right-click produces but without a mouse event — the app's
+ *       floating-joystick / mouse=false path, where a real button report
+ *       can't be sent. Emits nothing in the views where win-remove would
+ *       prompt (same gating as the click), so it's safe to send anywhere.
+ *   android-pl-add <name>
+ *       add the current view's selection (the selected event's file set)
+ *       to the named playlist; rest of line = name, verbatim.
+ *   android-pl-delete <name>
+ *       delete the named playlist (the selected event's playlist
+ *       variant); rest of line = name, verbatim.
+ *   android-winch
+ *       re-check the tty size and redraw. The app sends it after every
+ *       pty resize (and on connect): the kernel's SIGWINCH is lost if it
+ *       lands before the handler is installed (the app can resize the
+ *       just-spawned pty that early), and one landing between the
+ *       needs_to_resize check and the select entry sleeps until the next
+ *       wakeup — this line both sets the flag and *is* the wakeup.
+ *   android-jobs
+ *       answered immediately with a jobs event — a fresh authoritative
+ *       check at decision time for the app's idle-quit guard (which
+ *       must never quit mid-import and re-polls while a job runs).
+ *   android-save [kind ...]
+ *       write the named state-file kinds (resume settings library cache
+ *       playlist queue history; bare = everything, the exit path's whole
+ *       save set) without exiting, answered with a saved event once the
+ *       files are on disk — so the app can zip a fresh CMUS_HOME while
+ *       cmus keeps running, and debounce granular periodic saves off the
+ *       dirty events. Unknown kinds are ignored with a d_print.
+ */
+
+#include "android.h"
+#include "command_mode.h"
+#include "debug.h"
+#include "editable.h"
+#include "gbuf.h"
+#include "keyval.h"
+#include "lib.h"
+#include "list.h"
+#include "options.h"
+#include "output.h"
+#include "pl.h"
+#include "play_queue.h"
+#include "player.h"
+#include "search_mode.h"
+#include "track_info.h"
+#include "uchar.h"
+#include "ui_curses.h"
+#include "utils.h"
+#include "window.h"
+#include "worker.h"
+#include "xmalloc.h"
+
+#include <ctype.h>
+#include <errno.h>
+#include <fcntl.h>
+#include <stdlib.h>
+#include <string.h>
+#include <sys/socket.h>
+#include <sys/un.h>
+#include <unistd.h>
+
+int android_fd = -1;
+int android_client_fd = -1;
+
+static char *android_socket_path;
+
+/* connect-dirty: next flush sends the full snapshot */
+static int android_dirty_all;
+static int android_dirty_options;
+static int android_dirty_view;
+
+/* last jobs-running state sent; -1 = never sent */
+static int android_jobs_running = -1;
+
+/* last volume sent; -2 = never sent */
+static int android_vol_l = -2;
+static int android_vol_r = -2;
+
+/* last live filter sent; lib_live_filter has writers that bypass any
+ * command (resume restore, lib_set_filter's clear), so change detection
+ * is a diff in the flush, not a hook */
+static char *android_live_filter;
+
+/*
+ * The dirty event's per-kind mutation counters (indexes = the
+ * ANDROID_SAVE_* bit positions). counter bumps from the mutation hooks —
+ * atomically, since the cache mutates on the worker thread; everything
+ * else is main-loop only but uniform is simpler. saved = the counter
+ * value snapshotted *before* android_save_state wrote the files (a
+ * mid-save mutation leaves counter != saved and re-announces); announced
+ * = the last value sent, so each kind emits once per save cycle.
+ */
+#define ANDROID_NR_KINDS 7
+static const char * const android_kind_names[ANDROID_NR_KINDS] = {
+	"resume", "settings", "library", "cache", "playlist", "queue",
+	"history",
+};
+static long android_kind_counter[ANDROID_NR_KINDS];
+static long android_kind_saved[ANDROID_NR_KINDS];
+static long android_kind_announced[ANDROID_NR_KINDS];
+
+/* inbound partial-line buffer, persists across android_process calls */
+static char android_rbuf[4096];
+static int android_rbuf_pos;
+
+static void android_jobs_event(void);
+static void android_saved_event(int kinds);
+
+static void android_close_client(void)
+{
+	if (android_client_fd == -1)
+		return;
+	close(android_client_fd);
+	android_client_fd = -1;
+	android_rbuf_pos = 0;
+}
+
+void android_init(void)
+{
+	struct sockaddr_un addr;
+	const char *path = getenv("CMUS_ANDROID_SOCKET");
+
+	if (!path || !path[0])
+		return;
+	if (strlen(path) >= sizeof(addr.sun_path)) {
+		error_msg("CMUS_ANDROID_SOCKET is too long for sun_path");
+		return;
+	}
+
+	memset(&addr, 0, sizeof(addr));
+	addr.sun_family = AF_UNIX;
+	strcpy(addr.sun_path, path);
+
+	/* the app owns the directory; a leftover socket is always stale */
+	unlink(path);
+
+	android_fd = socket(AF_UNIX, SOCK_STREAM, 0);
+	if (android_fd == -1) {
+		error_msg("android socket: %s", strerror(errno));
+		return;
+	}
+	if (bind(android_fd, (struct sockaddr *)&addr, sizeof(addr)) == -1 ||
+			listen(android_fd, 1) == -1) {
+		error_msg("android socket %s: %s", path, strerror(errno));
+		close(android_fd);
+		android_fd = -1;
+		return;
+	}
+	fcntl(android_fd, F_SETFL, O_NONBLOCK);
+	android_socket_path = xstrdup(path);
+}
+
+void android_free(void)
+{
+	android_close_client();
+	if (android_fd != -1) {
+		close(android_fd);
+		android_fd = -1;
+	}
+	if (android_socket_path) {
+		unlink(android_socket_path);
+		free(android_socket_path);
+		android_socket_path = NULL;
+	}
+	free(android_live_filter);
+	android_live_filter = NULL;
+}
+
+void android_accept(void)
+{
+	int fd = accept(android_fd, NULL, NULL);
+	if (fd == -1)
+		return;
+
+	/* single client, new connection wins */
+	android_close_client();
+
+	fcntl(fd, F_SETFL, O_NONBLOCK);
+	android_client_fd = fd;
+	android_dirty_all = 1;
+
+	/* re-announce anything unsaved to the new client (a reconnect must
+	 * not lose dirt the old client hadn't saved yet) */
+	for (int i = 0; i < ANDROID_NR_KINDS; i++)
+		android_kind_announced[i] = android_kind_saved[i];
+}
+
+void android_state_dirty(int kinds)
+{
+	for (int i = 0; i < ANDROID_NR_KINDS; i++)
+		if (kinds & (1 << i))
+			__atomic_fetch_add(&android_kind_counter[i], 1,
+					__ATOMIC_RELAXED);
+}
+
+/*
+ * Classifies an editable mutation for the dirty event. The library is
+ * deliberately skipped: lib.pl is saved from the filename hash in
+ * canonical ti_cmp order (do_lib_for_each), so lib_editable
+ * sorts/moves never change the file — the hash_insert/hash_remove
+ * hooks in lib.c are the exact writers. Playlist/queue files are saved
+ * in editable order, so every mutation counts there.
+ */
+void android_editable_dirty(struct editable *e)
+{
+	if (e == &lib_editable)
+		return;
+	if (e == &pq_editable)
+		android_state_dirty(ANDROID_SAVE_QUEUE);
+	else
+		android_state_dirty(ANDROID_SAVE_PLAYLIST);
+}
+
+/*
+ * The selection the app acts on: the same per-view for-each-sel the
+ * multi-track commands use, so the set matches what win-remove would
+ * remove (marked tracks and all). Views whose win-remove prompts return
+ * nothing — but the playlist-view list pane is handled separately by
+ * android_selected_event.
+ */
+static int android_for_each_sel(track_info_cb cb, void *data)
+{
+	switch (cur_view) {
+	case TREE_VIEW:
+		return _tree_for_each_sel(cb, data, 0);
+	case SORTED_VIEW:
+		return _editable_for_each_sel(&lib_editable, cb, data, 0);
+	case PLAYLIST_VIEW:
+		if (pl_cursor_win() == pl_editable_shared.win)
+			return _pl_for_each_sel(cb, data, 0);
+		return 0;
+	case QUEUE_VIEW:
+		return _editable_for_each_sel(&pq_editable, cb, data, 0);
+	}
+	return 0;
+}
+
+static int android_pl_add_cb(void *data, struct track_info *ti)
+{
+	pl_add_track_to_marked_pl(ti);
+	return 0;
+}
+
+/*
+ * The android-pl-add input line: cmus can only add to the *marked*
+ * playlist, so mark the target by name, add the selection, and put the
+ * mark back where the user had it.
+ */
+static void android_pl_add(const char *name)
+{
+	char *saved = xstrdup(pl_marked_pl_name());
+
+	pl_set_marked_pl_by_name(name);
+	if (strcmp(pl_marked_pl_name(), name) == 0)
+		android_for_each_sel(android_pl_add_cb, NULL);
+	else
+		error_msg("couldn't find a playlist named '%s' to add to", name);
+	pl_set_marked_pl_by_name(saved);
+	free(saved);
+}
+
+/*
+ * The android-nav-* input lines: a far joystick slide means "go this
+ * way", which is the inner pane in the two-pane views and the adjacent
+ * view once at that side's edge (or in a single-pane view).
+ */
+static void android_nav(int right)
+{
+	int in_left_pane = -1; /* single-pane view */
+	struct window *right_win = NULL;
+	struct iter it;
+
+	if (cur_view == TREE_VIEW) {
+		in_left_pane = lib_cur_win == lib_tree_win;
+		right_win = lib_track_win;
+	} else if (cur_view == PLAYLIST_VIEW) {
+		in_left_pane = pl_cursor_win() != pl_editable_shared.win;
+		right_win = pl_editable_shared.win;
+	}
+
+	/* an empty track pane is a dead end, not a stop (pl's win-next
+	 * refuses to enter it anyway): fall through to the view switch */
+	if (in_left_pane == right &&
+			(!right || window_get_top(right_win, &it))) {
+		run_command("win-next");
+		return;
+	}
+	if (right)
+		run_command("right-view -n");
+	else
+		run_command("left-view -n");
+}
+
+static void android_run_line(const char *line)
+{
+	char *cmd, *arg;
+
+	while (isspace((unsigned char)*line))
+		line++;
+
+	if (strcmp(line, "android-nav-left") == 0) {
+		android_nav(0);
+		return;
+	}
+	if (strcmp(line, "android-nav-right") == 0) {
+		android_nav(1);
+		return;
+	}
+	if (strcmp(line, "android-selected") == 0) {
+		android_selected_event();
+		return;
+	}
+	if (strncmp(line, "android-pl-add ", 15) == 0) {
+		android_pl_add(line + 15);
+		return;
+	}
+	if (strncmp(line, "android-pl-delete ", 18) == 0) {
+		pl_delete_by_name((char *)(line + 18));
+		return;
+	}
+	if (strcmp(line, "android-winch") == 0) {
+		update_size();
+		return;
+	}
+	if (strcmp(line, "android-jobs") == 0) {
+		android_jobs_event();
+		return;
+	}
+	if (strcmp(line, "android-save") == 0 ||
+			strncmp(line, "android-save ", 13) == 0) {
+		long snap[ANDROID_NR_KINDS];
+		int kinds = 0, i;
+		const char *p = line + 12;
+
+		while (*p) {
+			int len;
+			while (*p == ' ')
+				p++;
+			if (!*p)
+				break;
+			len = strcspn(p, " ");
+			for (i = 0; i < ANDROID_NR_KINDS; i++) {
+				if (strlen(android_kind_names[i]) == (size_t)len &&
+						strncmp(p, android_kind_names[i], len) == 0) {
+					kinds |= 1 << i;
+					break;
+				}
+			}
+			if (i == ANDROID_NR_KINDS)
+				d_print("unknown android-save kind '%.*s'\n", len, p);
+			p += len;
+		}
+		if (line[12] == 0)
+			kinds = ANDROID_SAVE_ALL;
+
+		/* snapshot before writing: a mutation landing mid-save keeps
+		 * counter != saved and the kind re-announces next flush */
+		for (i = 0; i < ANDROID_NR_KINDS; i++)
+			snap[i] = __atomic_load_n(&android_kind_counter[i],
+					__ATOMIC_RELAXED);
+		android_save_state(kinds);
+		for (i = 0; i < ANDROID_NR_KINDS; i++)
+			if (kinds & (1 << i))
+				android_kind_saved[i] = snap[i];
+		android_saved_event(kinds);
+		return;
+	}
+
+	if (*line == '/' || *line == '?') {
+		int restricted = 0;
+		char prefix = *line++;
+		search_direction = prefix == '/' ?
+			SEARCH_FORWARD : SEARCH_BACKWARD;
+		if (*line == prefix) {
+			line++;
+			restricted = 1;
+		}
+		search_text(line, restricted, 1);
+	} else if (parse_command(line, &cmd, &arg)) {
+		run_parsed_command(cmd, arg);
+		free(cmd);
+		free(arg);
+	}
+}
+
+void android_process(void)
+{
+	while (1) {
+		int rc, s, i;
+
+		rc = read(android_client_fd, android_rbuf + android_rbuf_pos,
+				sizeof(android_rbuf) - android_rbuf_pos);
+		if (rc == -1) {
+			if (errno == EINTR)
+				continue;
+			if (errno == EAGAIN)
+				return;
+			android_close_client();
+			return;
+		}
+		if (rc == 0) {
+			android_close_client();
+			return;
+		}
+		android_rbuf_pos += rc;
+
+		s = 0;
+		for (i = 0; i < android_rbuf_pos; i++) {
+			if (android_rbuf[i] != '\n')
+				continue;
+			android_rbuf[i] = 0;
+			android_run_line(android_rbuf + s);
+			s = i + 1;
+			/* a command may close the socket (e.g. quit) */
+			if (android_client_fd == -1)
+				return;
+		}
+		memmove(android_rbuf, android_rbuf + s, android_rbuf_pos - s);
+		android_rbuf_pos -= s;
+
+		if (android_rbuf_pos == sizeof(android_rbuf)) {
+			d_print("android client sent an overlong line\n");
+			android_close_client();
+			return;
+		}
+	}
+}
+
+void android_options_changed(void)
+{
+	android_dirty_options = 1;
+}
+
+void android_view_changed(void)
+{
+	android_dirty_view = 1;
+}
+
+static void android_json_str(struct gbuf *buf, const char *str)
+{
+	/* tags aren't guaranteed UTF-8 and JSON requires it (mpris.c
+	 * precedent, including the VLA) */
+	char utf8[u_str_print_size(str)];
+	const char *s;
+
+	u_to_utf8(utf8, str);
+
+	gbuf_add_ch(buf, '"');
+	for (s = utf8; *s; s++) {
+		unsigned char ch = *s;
+		switch (ch) {
+		case '"':
+			gbuf_add_str(buf, "\\\"");
+			break;
+		case '\\':
+			gbuf_add_str(buf, "\\\\");
+			break;
+		default:
+			if (ch < 0x20)
+				gbuf_addf(buf, "\\u%04x", ch);
+			else
+				gbuf_add_ch(buf, ch);
+		}
+	}
+	gbuf_add_ch(buf, '"');
+}
+
+static void android_write(struct gbuf *buf)
+{
+	size_t off = 0;
+
+	while (off < buf->len) {
+		ssize_t rc = write(android_client_fd, buf->buffer + off,
+				buf->len - off);
+		if (rc == -1) {
+			if (errno == EINTR)
+				continue;
+			/* EAGAIN = stalled local reader with a full socket
+			 * buffer; drop it like a dead client, a reconnect
+			 * gets a fresh snapshot */
+			d_print("android client write: %s\n", strerror(errno));
+			android_close_client();
+			return;
+		}
+		off += rc;
+	}
+}
+
+struct android_sel_ctx {
+	struct gbuf *buf;
+	int count;
+};
+
+static int android_sel_cb(void *data, struct track_info *ti)
+{
+	struct android_sel_ctx *ctx = data;
+
+	if (ctx->count++)
+		gbuf_add_ch(ctx->buf, ',');
+	android_json_str(ctx->buf, ti->filename);
+	return 0;
+}
+
+static void android_pl_name_cb(const char *name, void *data)
+{
+	struct android_sel_ctx *ctx = data;
+
+	if (ctx->count++)
+		gbuf_add_ch(ctx->buf, ',');
+	android_json_str(ctx->buf, name);
+}
+
+/*
+ * Right-click resolved to a list row (normal_mode_mouse; the selection has
+ * already moved there). Emits the "selected" event per the protocol
+ * comment: the win-remove target set + the playlist names for the app's
+ * add-to chooser, or the playlist-name variant for the playlist view's
+ * list pane (where the selected playlist is the visible one).
+ */
+void android_selected_event(void)
+{
+	GBUF(buf);
+	struct android_sel_ctx ctx = { .buf = &buf };
+
+	if (android_client_fd == -1)
+		return;
+
+	if (cur_view == PLAYLIST_VIEW &&
+			pl_cursor_win() != pl_editable_shared.win) {
+		gbuf_add_str(&buf, "{\"type\":\"selected\","
+				"\"view\":\"playlist\",\"playlist\":");
+		android_json_str(&buf, pl_visible_get_name());
+		gbuf_add_str(&buf, "}\n");
+		android_write(&buf);
+		gbuf_free(&buf);
+		return;
+	}
+
+	gbuf_addf(&buf, "{\"type\":\"selected\",\"view\":\"%s\",\"files\":[",
+			view_names[cur_view]);
+	android_for_each_sel(android_sel_cb, &ctx);
+	if (ctx.count) {
+		gbuf_add_str(&buf, "],\"playlists\":[");
+		ctx.count = 0;
+		pl_android_for_each_name(android_pl_name_cb, &ctx);
+		gbuf_add_str(&buf, "]}\n");
+		android_write(&buf);
+	}
+	gbuf_free(&buf);
+}
+
+/*
+ * The android-jobs poll's answer, immediate like the selected event.
+ * Updates the flush diff's cache so the same state isn't re-sent.
+ */
+static void android_jobs_event(void)
+{
+	GBUF(buf);
+
+	if (android_client_fd == -1)
+		return;
+
+	android_jobs_running = worker_has_job() ? 1 : 0;
+	gbuf_addf(&buf, "{\"type\":\"jobs\",\"running\":%s}\n",
+			android_jobs_running ? "true" : "false");
+	android_write(&buf);
+	gbuf_free(&buf);
+}
+
+/*
+ * The android-save line's ack: android_save_state has returned, so the
+ * state files are written and renamed into place. "what" echoes the
+ * request's kinds; acks arrive in request order.
+ */
+static void android_saved_event(int kinds)
+{
+	GBUF(buf);
+	int i, first = 1;
+
+	if (android_client_fd == -1)
+		return;
+
+	gbuf_add_str(&buf, "{\"type\":\"saved\",\"what\":[");
+	for (i = 0; i < ANDROID_NR_KINDS; i++) {
+		if (!(kinds & (1 << i)))
+			continue;
+		if (!first)
+			gbuf_add_ch(&buf, ',');
+		first = 0;
+		gbuf_addf(&buf, "\"%s\"", android_kind_names[i]);
+	}
+	gbuf_add_str(&buf, "]}\n");
+	android_write(&buf);
+	gbuf_free(&buf);
+}
+
+/*
+ * A colorscheme command sourced a theme file (command_mode.c hooks the
+ * success path only). The name is the app's theme-selector highlight;
+ * the color options themselves follow in the flushed options event.
+ */
+void android_colorscheme_event(const char *name)
+{
+	GBUF(buf);
+
+	if (android_client_fd == -1)
+		return;
+
+	gbuf_add_str(&buf, "{\"type\":\"colorscheme\",\"name\":");
+	android_json_str(&buf, name);
+	gbuf_add_str(&buf, "}\n");
+	android_write(&buf);
+	gbuf_free(&buf);
+}
+
+static void android_status_event(struct gbuf *buf)
+{
+	const struct track_info *ti = player_info.ti;
+	int i;
+
+	gbuf_addf(buf, "{\"type\":\"status\",\"status\":\"%s\"",
+			player_status_names[player_info.status]);
+	if (ti) {
+		gbuf_add_str(buf, ",\"file\":");
+		android_json_str(buf, ti->filename);
+		gbuf_addf(buf, ",\"duration\":%d,\"position\":%.3f,\"tags\":{",
+				ti->duration, player_pos_exact());
+		for (i = 0; ti->comments[i].key; i++) {
+			if (i)
+				gbuf_add_ch(buf, ',');
+			android_json_str(buf, ti->comments[i].key);
+			gbuf_add_ch(buf, ':');
+			android_json_str(buf, ti->comments[i].val);
+		}
+		gbuf_add_ch(buf, '}');
+	}
+	gbuf_add_str(buf, "}\n");
+}
+
+static void android_options_event(struct gbuf *buf)
+{
+	char optbuf[OPTION_MAX_SIZE];
+	struct cmus_opt *opt;
+	int first = 1;
+
+	gbuf_add_str(buf, "{\"type\":\"options\",\"options\":{");
+	list_for_each_entry(opt, &option_head, node) {
+		opt->get(opt->data, optbuf, OPTION_MAX_SIZE);
+		if (!first)
+			gbuf_add_ch(buf, ',');
+		first = 0;
+		android_json_str(buf, opt->name);
+		gbuf_add_ch(buf, ':');
+		android_json_str(buf, optbuf);
+	}
+	gbuf_add_str(buf, "}}\n");
+}
+
+void android_flush(void)
+{
+	GBUF(buf);
+	int vol_l, vol_r;
+	int status_dirty;
+	int jobs_running;
+
+	if (android_client_fd == -1)
+		return;
+
+	/* same computation as server.c cmd_status */
+	if (soft_vol) {
+		vol_l = soft_vol_l;
+		vol_r = soft_vol_r;
+	} else if (!volume_max) {
+		vol_l = vol_r = -1;
+	} else {
+		vol_l = scale_to_percentage(volume_l, volume_max);
+		vol_r = scale_to_percentage(volume_r, volume_max);
+	}
+
+	/* player_info's *_changed flags are snapshotted at the top of the
+	 * main-loop iteration and stay valid until the next snapshot; this
+	 * runs right after update() and sees what mpris' callbacks see */
+	status_dirty = android_dirty_all || player_info.status_changed ||
+		player_info.file_changed || player_info.metadata_changed;
+
+	if (android_dirty_all)
+		gbuf_addf(&buf, "{\"type\":\"hello\",\"version\":\"%s\"}\n",
+				VERSION);
+	if (status_dirty)
+		android_status_event(&buf);
+	else if (player_info.position_changed)
+		gbuf_addf(&buf, "{\"type\":\"position\",\"position\":%.3f}\n",
+				player_pos_exact());
+	if (android_dirty_all || vol_l != android_vol_l ||
+			vol_r != android_vol_r) {
+		gbuf_addf(&buf, "{\"type\":\"volume\",\"left\":%d,\"right\":%d}\n",
+				vol_l, vol_r);
+		android_vol_l = vol_l;
+		android_vol_r = vol_r;
+	}
+	if (android_dirty_all || android_dirty_view)
+		gbuf_addf(&buf, "{\"type\":\"view\",\"view\":\"%s\"}\n",
+				view_names[cur_view]);
+	if (android_dirty_all || strcmp0(lib_live_filter, android_live_filter)) {
+		gbuf_add_str(&buf, "{\"type\":\"filter\"");
+		if (lib_live_filter) {
+			gbuf_add_str(&buf, ",\"filter\":");
+			android_json_str(&buf, lib_live_filter);
+		}
+		gbuf_add_str(&buf, "}\n");
+		free(android_live_filter);
+		android_live_filter = lib_live_filter ? xstrdup(lib_live_filter) : NULL;
+	}
+	/* per-kind unsaved-change announcements, edge-triggered per save
+	 * cycle (see the protocol comment); before the jobs diff so a
+	 * client processing in order arms its debounce before it sees a
+	 * job-completion edge */
+	{
+		int i, first = 1;
+
+		for (i = 0; i < ANDROID_NR_KINDS; i++) {
+			long c = __atomic_load_n(&android_kind_counter[i],
+					__ATOMIC_RELAXED);
+			if (c == android_kind_saved[i] ||
+					c == android_kind_announced[i])
+				continue;
+			gbuf_addf(&buf, "%s\"%s\"",
+					first ? "{\"type\":\"dirty\",\"what\":[" : ",",
+					android_kind_names[i]);
+			first = 0;
+			android_kind_announced[i] = c;
+		}
+		if (!first)
+			gbuf_add_str(&buf, "]}\n");
+	}
+	/* diffed like volume; promptness is job_fd's doing (see the
+	 * protocol comment) */
+	jobs_running = worker_has_job() ? 1 : 0;
+	if (android_dirty_all || jobs_running != android_jobs_running) {
+		gbuf_addf(&buf, "{\"type\":\"jobs\",\"running\":%s}\n",
+				jobs_running ? "true" : "false");
+		android_jobs_running = jobs_running;
+	}
+	if (android_dirty_all || android_dirty_options)
+		android_options_event(&buf);
+
+	android_dirty_all = 0;
+	android_dirty_options = 0;
+	android_dirty_view = 0;
+
+	if (buf.len)
+		android_write(&buf);
+	gbuf_free(&buf);
+}
