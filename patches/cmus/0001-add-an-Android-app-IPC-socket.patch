+#ifdef CONFIG_ANDROID
+/*
+ * exit_all's save set (resume, autosave, queue, library, playlists,
+ * histories, cache) — or any ANDROID_SAVE_* subset — without exiting
+ * or freeing anything; every callee is repeat-safe and, with patch
+ * 0004's atomic cmus_save, a write-tmp-and-rename writer. Backs the
+ * android-save input line (zip export wants fresh files; the app's
+ * debounced periodic saves send subsets). Unlike the exit path, the
+ * worker is still running here, so the cache write takes cache_lock —
+ * job.c mutates the cache hash table on the worker thread, and
+ * upstream only ever calls cache_close after job_exit.
+ */
+void android_save_state(int kinds)
+{
+	if ((kinds & ANDROID_SAVE_RESUME) && resume_cmus)
+		resume_exit();
+	if (kinds & ANDROID_SAVE_SETTINGS)
+		options_exit();
+	if ((kinds & ANDROID_SAVE_QUEUE) && resume_cmus)
+		cmus_save(play_queue_for_each, play_queue_autosave_filename,
+				NULL);
+	if (kinds & ANDROID_SAVE_LIBRARY)
+		cmus_save(lib_for_each, lib_autosave_filename, NULL);
+	if (kinds & ANDROID_SAVE_PLAYLIST)
+		pl_save();
+	if (kinds & ANDROID_SAVE_HISTORY) {
+		commands_save();
+		search_mode_save();
+	}
+	if (kinds & ANDROID_SAVE_CACHE) {
+		cache_lock();
+		if (cache_close())
+			d_print("saving cache: %s\n", strerror(errno));
+		cache_unlock();
+	}
+}
+#endif
