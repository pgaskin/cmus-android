+#ifdef CONFIG_ANDROID
+/* Exact playing position for the android IPC; player_info.pos is whole
+ * seconds, which makes a client animating between position events jump
+ * back on rebase (e.g. pause).
+ *
+ * This runs in the main loop every flush and must NEVER block: at a track
+ * boundary the consumer thread holds consumer_mutex across its blocking
+ * get_next callback (cmus_get_next_track cond-waits), and only the main
+ * loop can answer that request — a plain player_lock() here deadlocks the
+ * whole player. Trylock instead, falling back to the snapshot's
+ * whole-second position for the rare contended iteration (the next event
+ * rebases fractionally again; clients never notice). */
+double player_pos_exact(void)
+{
+	double pos;
+
+	if (pthread_mutex_trylock(&consumer_mutex) != 0)
+		return (double)player_info.pos;
+	if (pthread_mutex_trylock(&producer_mutex) != 0) {
+		pthread_mutex_unlock(&consumer_mutex);
+		return (double)player_info.pos;
+	}
+	pos = (double)player_info.pos;
+	if (consumer_status == CS_PLAYING || consumer_status == CS_PAUSED)
+		pos = (double)consumer_pos / (double)buffer_second_size();
+	pthread_mutex_unlock(&producer_mutex);
+	pthread_mutex_unlock(&consumer_mutex);
+	return pos;
+}
+#endif
