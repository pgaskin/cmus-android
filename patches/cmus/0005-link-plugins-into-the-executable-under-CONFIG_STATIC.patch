+ * but WITHOUT ANY WARRANTY; without even the implied warranty of
+ * MERCHANTABILITY or FITNESS FOR A PARTICULAR PURPOSE.  See the
+ * GNU General Public License for more details.
+ *
+ * You should have received a copy of the GNU General Public License along
+ * with this program; if not, write to the Free Software Foundation, Inc.,
+ * 51 Franklin Street, Fifth Floor, Boston, MA 02110-1301 USA.
+ */
+
+#ifndef CMUS_STATIC_PLUGINS_H
+#define CMUS_STATIC_PLUGINS_H
+
+#ifdef CONFIG_STATIC_PLUGINS
+
+#include "ip.h"
+#include "op.h"
+#include "mixer.h"
+
+/*
+ * When plugins are linked into the cmus executable instead of loaded from
+ * <libdir>/{ip,op}/<name>.so, each plugin's fixed ABI symbols (ip_ops, ip_priority,
+ * ...) are renamed to <name>_ip_ops etc. at compile time, and these tables
+ * take the place of the dlopen()/dlsym() scan. See static_plugins.c.
+ */
+
+struct static_ip {
+	const char *name;
+	const unsigned *abi_version;
+	const int *priority;
+	const char * const *extensions;
+	const char * const *mime_types;
+	const struct input_plugin_ops *ops;
+	const struct input_plugin_opt *options;
+};
+
+struct static_op {
+	const char *name;
+	const unsigned *abi_version;
+	const int *priority;
+	const struct output_plugin_ops *pcm_ops;
+	const struct output_plugin_opt *pcm_options;
+	/* mixer_ops/mixer_options are NULL for plugins without a mixer */
+	const struct mixer_plugin_ops *mixer_ops;
+	const struct mixer_plugin_opt *mixer_options;
+};
+
+extern const struct static_ip static_ip_plugins[];
+extern const int static_ip_plugins_nr;
+extern const struct static_op static_op_plugins[];
+extern const int static_op_plugins_nr;
+
+#endif
+
+#endif
