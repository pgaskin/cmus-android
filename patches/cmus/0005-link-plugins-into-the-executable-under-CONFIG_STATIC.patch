+ * with this program; if not, write to the Free Software Foundation, Inc.,
+ * 51 Franklin Street, Fifth Floor, Boston, MA 02110-1301 USA.
+ */
+
+#include "static_plugins.h"
+
+#ifdef CONFIG_STATIC_PLUGINS
+
+#include <stddef.h>
+
+/*
+ * Each plugin translation unit is compiled with its fixed ABI symbols renamed
+ * to <sym>_ip_* / <sym>_op_* (see native/cmus/CMakeLists.txt). Declare the
+ * renamed symbols and gather them into the tables the loaders walk.
+ */
+
+#define IP_DECL(sym) \
+	extern const unsigned sym##_ip_abi_version; \
+	extern const int sym##_ip_priority; \
+	extern const char * const sym##_ip_extensions[]; \
+	extern const char * const sym##_ip_mime_types[]; \
+	extern const struct input_plugin_ops sym##_ip_ops; \
+	extern const struct input_plugin_opt sym##_ip_options[];
+
+#define IP_ENTRY(nm, sym) { \
+	nm, &sym##_ip_abi_version, &sym##_ip_priority, \
+	sym##_ip_extensions, sym##_ip_mime_types, &sym##_ip_ops, sym##_ip_options }
+
+#define OP_DECL(sym) \
+	extern const unsigned sym##_op_abi_version; \
+	extern const int sym##_op_priority; \
+	extern const struct output_plugin_ops sym##_op_pcm_ops; \
+	extern const struct output_plugin_opt sym##_op_pcm_options[];
+
+#define OP_MIXER_DECL(sym) \
+	OP_DECL(sym) \
+	extern const struct mixer_plugin_ops sym##_op_mixer_ops; \
+	extern const struct mixer_plugin_opt sym##_op_mixer_options[];
+
+#define OP_ENTRY(nm, sym) { \
+	nm, &sym##_op_abi_version, &sym##_op_priority, \
+	&sym##_op_pcm_ops, sym##_op_pcm_options, NULL, NULL }
+
+#define OP_MIXER_ENTRY(nm, sym) { \
+	nm, &sym##_op_abi_version, &sym##_op_priority, \
+	&sym##_op_pcm_ops, sym##_op_pcm_options, &sym##_op_mixer_ops, sym##_op_mixer_options }
+
+IP_DECL(flac)
+IP_DECL(vorbis)
+IP_DECL(opus)
+IP_DECL(mad)
+IP_DECL(wavpack)
+IP_DECL(aac)
+IP_DECL(mp4)
+IP_DECL(wav)
+IP_DECL(cue)
+
+const struct static_ip static_ip_plugins[] = {
+	IP_ENTRY("flac", flac),
+	IP_ENTRY("vorbis", vorbis),
+	IP_ENTRY("opus", opus),
+	IP_ENTRY("mad", mad),
+	IP_ENTRY("wavpack", wavpack),
+	IP_ENTRY("aac", aac),
+	IP_ENTRY("mp4", mp4),
+	IP_ENTRY("wav", wav),
+	IP_ENTRY("cue", cue),
+};
+const int static_ip_plugins_nr =
+	sizeof(static_ip_plugins) / sizeof(static_ip_plugins[0]);
+
+OP_MIXER_DECL(aaudio)
+
+const struct static_op static_op_plugins[] = {
+	OP_MIXER_ENTRY("aaudio", aaudio),
+};
+const int static_op_plugins_nr =
+	sizeof(static_op_plugins) / sizeof(static_op_plugins[0]);
+
+#endif
diff --git a/static_plugins.h b/static_plugins.h
new file mode 100644
index 0000000..cf4e4f5
--- /dev/null
+++ b/static_plugins.h
@@ -0,0 +1,63 @@
+/*
+ * Copyright 2008-2013 Various Authors
+ *
+ * This program is free software; you can redistribute it and/or modify
+ * it under the terms of the GNU General Public License as published by
+ * the Free Software Foundation; either version 2 of the License, or
+ * (at your option) any later version.
