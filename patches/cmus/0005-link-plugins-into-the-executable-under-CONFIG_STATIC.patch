From 18ffa3a0e92a4ea7707e874d507056d0cbea3aea Mon Sep 17 00:00:00 2001
From: "Claude Opus 4.8" <noreply@anthropic.com>
Date: Sun, 19 Jul 2026 19:34:55 -0400
Subject: [PATCH 05/13] link plugins into the executable under
 CONFIG_STATIC_PLUGINS

Instead of dlopen()ing <libdir>/{ip,op}/*.so, compile every plugin into
the cmus binary and register them from static tables. Each plugin's fixed
ABI symbols (ip_ops, ip_priority, ...) are renamed to <name>_ip_ops etc.
by the build so they no longer collide, and static_plugins.c gathers them
into static_ip_plugins[] / static_op_plugins[] which ip_load_plugins() and
op_load_plugins() walk in place of the directory scan.

Android-specific: the build defines CONFIG_STATIC_PLUGINS; the upstream
Makefile leaves it unset and keeps the dlopen path.

Co-Authored-By: Claude Opus 4.8 <noreply@anthropic.com>

diff --git a/input.c b/input.c
index 0f5e5b9..16757d2 100644
--- a/input.c
+++ b/input.c
@@ -34,6 +34,7 @@
 #include "ui_curses.h"
 #include "locking.h"
 #include "xstrjoin.h"
+#include "static_plugins.h"
 
 #include <unistd.h>
 #include <stdbool.h>
@@ -508,6 +509,35 @@ static int sort_ip(const struct list_head *a_, const struct list_head *b_)
 
 void ip_load_plugins(void)
 {
+#ifdef CONFIG_STATIC_PLUGINS
+	int i;
+
+	plugin_dir = "built-in";
+
+	ip_wrlock();
+	for (i = 0; i < static_ip_plugins_nr; i++) {
+		const struct static_ip *sp = &static_ip_plugins[i];
+		struct ip *ip;
+
+		if (!sp->abi_version || *sp->abi_version != IP_ABI_VERSION) {
+			error_msg("%s: incompatible plugin version", sp->name);
+			continue;
+		}
+
+		ip = xnew(struct ip, 1);
+		ip->extensions = sp->extensions;
+		ip->mime_types = sp->mime_types;
+		ip->ops = sp->ops;
+		ip->options = sp->options;
+		ip->priority = *sp->priority;
+		ip->name = xstrdup(sp->name);
+		ip->handle = NULL;
+
+		list_add_tail(&ip->node, &ip_head);
+	}
+	list_mergesort(&ip_head, sort_ip);
+	ip_unlock();
+#else
 	DIR *dir;
 	struct dirent *d;
 
@@ -575,6 +605,7 @@ void ip_load_plugins(void)
 	list_mergesort(&ip_head, sort_ip);
 	closedir(dir);
 	ip_unlock();
+#endif
 }
 
 struct input_plugin *ip_new(const char *filename)
diff --git a/output.c b/output.c
index a31677a..44461ed 100644
--- a/output.c
+++ b/output.c
@@ -28,6 +28,7 @@
 #include "options.h"
 #include "xstrjoin.h"
 #include "misc.h"
+#include "static_plugins.h"
 
 #include <string.h>
 #include <strings.h>
@@ -82,6 +83,36 @@ static void add_plugin(struct output_plugin *plugin)
 
 void op_load_plugins(void)
 {
+#ifdef CONFIG_STATIC_PLUGINS
+	int i;
+
+	plugin_dir = "built-in";
+
+	for (i = 0; i < static_op_plugins_nr; i++) {
+		const struct static_op *sp = &static_op_plugins[i];
+		struct output_plugin *plug;
+
+		if (!sp->abi_version || *sp->abi_version != OP_ABI_VERSION) {
+			error_msg("%s: incompatible plugin version", sp->name);
+			continue;
+		}
+
+		plug = xnew(struct output_plugin, 1);
+		plug->abi_version_ptr = sp->abi_version;
+		plug->pcm_ops = sp->pcm_ops;
+		plug->pcm_options = sp->pcm_options;
+		plug->mixer_ops = sp->mixer_ops;
+		plug->mixer_options = sp->mixer_options;
+		plug->priority = *sp->priority;
+		plug->name = xstrdup(sp->name);
+		plug->handle = NULL;
+		plug->pcm_initialized = 0;
+		plug->mixer_initialized = 0;
+		plug->mixer_open = 0;
+
+		add_plugin(plug);
+	}
+#else
 	DIR *dir;
 	struct dirent *d;
 
@@ -151,6 +182,7 @@ void op_load_plugins(void)
 		add_plugin(plug);
 	}
 	closedir(dir);
+#endif
 }
 
 static void init_plugin(struct output_plugin *o)
diff --git a/static_plugins.c b/static_plugins.c
new file mode 100644
index 0000000..d02da96
--- /dev/null
+++ b/static_plugins.c
@@ -0,0 +1,94 @@
